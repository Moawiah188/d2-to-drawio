faded: {
  style: {
    opacity: 0.4
    fill: "#FFE0C7"
    stroke: "#D35F0A"
    stroke-width: 3
  }
}
dashed: {
  style: {
    stroke-dash: 5
    border-radius: 10
  }
}
shadowed: {
  style: {
    shadow: true
    bold: true
    font-size: 20
    font-color: "#0D32B2"
  }
}
tripled: {
  style: {
    multiple: true
    3d: true
    double-border: true
  }
}
patterned: {
  style: {
    fill-pattern: dots
    text-transform: uppercase
    italic: true
    underline: true
  }
}
pulse -> faded: {
  style: {
    animated: true
    stroke: "#9B1A48"
  }
}
