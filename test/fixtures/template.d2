classes: {
  zone: {
    style: {
      fill: "#F9F9F9"
      stroke: "#666666"
      font-color: "#333333"
      border-radius: 8
    }
  }
  svc: {
    style: {
      fill: "#DAE8FC"
      stroke: "#6C8EBF"
      border-radius: 4
    }
  }
  ext: {
    style: {
      fill: "#FFF2CC"
      stroke: "#D6B656"
      stroke-dash: 4
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#D5E8D4"
      stroke: "#82B366"
      stroke-width: 2
    }
  }
  flow: {
    style: {
      stroke: "#4D4D4D"
      stroke-width: 2
    }
  }
  dep: {
    style: {
      stroke: "#999999"
      stroke-dash: 3
    }
  }
}
